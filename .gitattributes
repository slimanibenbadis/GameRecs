# Auto detect text files and perform LF normalization
* text=auto eol=lf

# TypeScript and JavaScript files
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf

# HTML and CSS files
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf

# Java files
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf

# Docker files
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Documentation
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.jar binary 